# --- 端口配置 ---
# API 服务端口 (默认 18789)
OPENCLAW_API_PORT=19791
# 控制台/其他服务端口 (默认 18790)
OPENCLAW_CTRL_PORT=19891

# --- 路径配置 ---
# 宿主机挂载路径 (支持 ~/ 或相对路径 ./)
# Windows 用户如果使用 CMD，建议直接写绝对路径，如 C:/Users/name/.openclaw-uos
OPENCLAW_DATA_PATH=~/.openclaw-uos
# 容器内工作空间路径（必须在/home/node下，因为node用户的家目录是这个）
OPENCLAW_WORKSPACE=/home/node/workspace


# --- 运行环境 ---
NODE_ENV=production